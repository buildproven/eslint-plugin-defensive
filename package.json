{
  "name": "eslint-plugin-defensive",
  "version": "1.0.0",
  "description": "ESLint plugin for defensive coding patterns - catches issues that standard lint/type checks miss",
  "main": "index.js",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "defensive",
    "security",
    "best-practices"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^8.57.1",
    "eslint": "^8.57.0",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^6.0.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.js",
    "rules/",
    "configs/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/brettstark73/eslint-plugin-defensive"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dead-code": "npx knip",
    "pattern-check": "bash scripts/pattern-check.sh || true",
    "security:scan": "bash scripts/run-semgrep.sh",
    "license:check": "npx license-checker --production --failOn 'GPL-2.0;GPL-3.0;AGPL-1.0;AGPL-3.0;SSPL-1.0;BSL-1.1' --excludePrivatePackages"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
